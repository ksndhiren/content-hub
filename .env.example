# Content Hub — environment configuration
# Copy this file to .env and fill in real values. .env is gitignored.

# OpenAI — required for SEO Agent, Content Writer Agent, and Graphic Generator Agent
OPENAI_API_KEY=sk-...

# Image model used by the Graphic Generator Agent
# Options: gpt-image-1 (recommended), dall-e-3
OPENAI_IMAGE_MODEL=gpt-image-1

# Chat model used by the Writer agent + JSON structuring step of SEO agent
OPENAI_CHAT_MODEL=gpt-4o-mini

# Web-search-enabled model used by the SEO agent for live trend research.
# Options: gpt-4o-mini-search-preview (cheap), gpt-4o-search-preview (best)
OPENAI_SEARCH_MODEL=gpt-4o-mini-search-preview

# Pexels — used by the Graphic Generator when a real human/scene photo is needed.
# Free key: https://www.pexels.com/api/
# Optional: if missing, the agent always uses pure AI-generated imagery instead.
PEXELS_API_KEY=

